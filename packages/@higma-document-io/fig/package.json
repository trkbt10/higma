{
  "name": "@higma-document-io/fig",
  "version": "0.12.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "bin": {
    "fig-lint": "./src/lint/cli/bin.ts"
  },
  "dependencies": {
    "@higma-codecs/compression": "workspace:*",
    "@higma-figma-containers/canvas": "workspace:*",
    "@higma-figma-containers/package": "workspace:*",
    "@higma-figma-runtime/kiwi-canvas": "workspace:*",
    "@higma-figma-runtime/roundtrip": "workspace:*",
    "@higma-figma-schema/profiles": "workspace:*",
    "@higma-primitives/tree": "workspace:*",
    "@higma-primitives/zip": "workspace:*",
    "@higma-document-models/fig": "workspace:*",
    "@higma-codecs/kiwi": "workspace:*",
    "pako": "^2.1.0"
  },
  "scripts": {
    "lint": "cd ../../.. && eslint packages/@higma-document-io/fig/src",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir ../../..",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-document-io/fig/src'"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./parser": {
      "types": "./src/parser/index.ts",
      "default": "./src/parser/index.ts"
    },
    "./validator": {
      "types": "./src/validator/index.ts",
      "default": "./src/validator/index.ts"
    },
    "./lint": {
      "types": "./src/lint/index.ts",
      "default": "./src/lint/index.ts"
    },
    "./context": {
      "types": "./src/context/index.ts",
      "default": "./src/context/index.ts"
    },
    "./export": {
      "types": "./src/export/index.ts",
      "default": "./src/export/index.ts"
    },
    "./roundtrip": {
      "types": "./src/roundtrip/index.ts",
      "default": "./src/roundtrip/index.ts"
    },
    "./page-ops": {
      "types": "./src/page-ops/index.ts",
      "default": "./src/page-ops/index.ts"
    },
    "./node-ops": {
      "types": "./src/node-ops/index.ts",
      "default": "./src/node-ops/index.ts"
    }
  },
  "higma": {
    "boundary": {
      "layer": 6,
      "family": "document-io",
      "product": "fig"
    }
  }
}
