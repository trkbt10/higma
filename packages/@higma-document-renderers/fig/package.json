    },
    "./text/paths": {
      "types": "./src/text/paths/index.ts",
      "default": "./src/text/paths/index.ts"
    },
    "./text/rendering": {
      "types": "./src/text/rendering/index.ts",
      "default": "./src/text/rendering/index.ts"
    },
    "./scene-graph": {
