{
  "name": "@higma-document-renderers/fig",
  "version": "0.12.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@higma-document-models/fig": "workspace:*",
    "@higma-primitives/tree": "workspace:*",
    "earcut": "^3.0.2",
    "opentype.js": "^1.3.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-document-renderers/fig/src'",
    "snapshot:generate": "bun run scripts/generate-snapshots.ts",
    "test:webgl": "vitest run --config ../../../vitest.config.ts spec/renderer/webgl/comparison.spec.ts spec/renderer/webgl/background-blur.spec.ts spec/renderer/webgl/effect-attributes.spec.ts",
    "test:webgl:update": "vitest run --config ../../../vitest.config.ts spec/renderer/webgl/comparison.spec.ts spec/renderer/webgl/background-blur.spec.ts spec/renderer/webgl/effect-attributes.spec.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
