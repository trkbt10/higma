{
  "name": "@higma-tools/refine-fig",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "bin": {
    "refine-fig": "./src/cli/bin.ts"
  },
  "scripts": {
    "lint": "cd ../../.. && eslint packages/@higma-tools/refine-fig/src packages/@higma-tools/refine-fig/spec",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir ../../..",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-tools/refine-fig/src' '../../../packages/@higma-tools/refine-fig/spec'"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./analysis": {
      "types": "./src/analysis/index.ts",
      "default": "./src/analysis/index.ts"
    },
    "./inventory": {
      "types": "./src/inventory/index.ts",
      "default": "./src/inventory/index.ts"
    },
    "./decisions": {
      "types": "./src/decisions/index.ts",
      "default": "./src/decisions/index.ts"
    },
    "./workbench": {
      "types": "./src/workbench/index.ts",
      "default": "./src/workbench/index.ts"
    },
    "./componentize": {
      "types": "./src/componentize/index.ts",
      "default": "./src/componentize/index.ts"
    },
    "./plan": {
      "types": "./src/plan/index.ts",
      "default": "./src/plan/index.ts"
    },
    "./apply": {
      "types": "./src/apply/index.ts",
      "default": "./src/apply/index.ts"
    },
    "./structure-diff": {
      "types": "./src/structure-diff/index.ts",
      "default": "./src/structure-diff/index.ts"
    },
    "./visual": {
      "types": "./src/visual/index.ts",
      "default": "./src/visual/index.ts"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "default": "./src/cli/index.ts"
    }
  },
  "dependencies": {
    "@higma-codecs/png-compare": "workspace:*",
    "@higma-document-editors/fig": "workspace:*",
    "@higma-document-io/fig": "workspace:*",
    "@higma-document-models/fig": "workspace:*",
    "@higma-document-renderers/fig": "workspace:*",
    "@higma-primitives/identifier": "workspace:*",
    "@higma-primitives/path": "workspace:*",
    "@higma-primitives/tree": "workspace:*"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/pngjs": "^6.0.5",
    "pngjs": "^7.0.0"
  },
  "higma": {
    "boundary": {
      "layer": 7,
      "family": "tools",
      "product": "fig"
    }
  }
}
