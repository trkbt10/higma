{
  "name": "@higma-tools/fig-to-swiftui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "bin": {
    "fig-to-swiftui": "./src/cli/bin.ts"
  },
  "scripts": {
    "lint": "cd ../../.. && eslint packages/@higma-tools/fig-to-swiftui/src packages/@higma-tools/fig-to-swiftui/spec packages/@higma-tools/fig-to-swiftui/scripts",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir ../../..",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-tools/fig-to-swiftui/src' '../../../packages/@higma-tools/fig-to-swiftui/spec'",
    "render-case": "bun scripts/render-case.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./emit": {
      "types": "./src/emit/index.ts",
      "default": "./src/emit/index.ts"
    },
    "./swift-tree": {
      "types": "./src/swift-tree/index.ts",
      "default": "./src/swift-tree/index.ts"
    },
    "./render": {
      "types": "./src/render/index.ts",
      "default": "./src/render/index.ts"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "default": "./src/cli/index.ts"
    }
  },
  "dependencies": {
    "@higma-document-io/fig": "workspace:*",
    "@higma-document-models/fig": "workspace:*",
    "@higma-document-renderers/fig": "workspace:*",
    "@higma-primitives/identifier": "workspace:*",
    "@higma-primitives/path": "workspace:*",
    "@higma-tools/web-fig-roundtrip": "workspace:*"
  },
  "devDependencies": {
    "@higma-codecs/png-compare": "workspace:*"
  },
  "boundaryNote": "web-fig-roundtrip is a runtime dependency only when --rasterize-threshold is in use; otherwise the CLI does not load it.",
  "higma": {
    "boundary": {
      "layer": 7,
      "family": "tools",
      "product": "fig"
    }
  }
}
