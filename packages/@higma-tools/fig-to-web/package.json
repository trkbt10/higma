{
  "name": "@higma-tools/fig-to-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "bin": {
    "fig-to-web": "./src/cli/bin.ts"
  },
  "scripts": {
    "lint": "cd ../../.. && eslint packages/@higma-tools/fig-to-web/src packages/@higma-tools/fig-to-web/spec",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir ../../..",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-tools/fig-to-web/src' '../../../packages/@higma-tools/fig-to-web/spec'"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./emit": {
      "types": "./src/emit/index.ts",
      "default": "./src/emit/index.ts"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "default": "./src/cli/index.ts"
    }
  },
  "dependencies": {
    "@higma-bridges/web-fig": "workspace:*",
    "@higma-document-io/fig": "workspace:*",
    "@higma-document-models/fig": "workspace:*",
    "@higma-document-renderers/fig": "workspace:*",
    "@higma-figma-containers/package": "workspace:*",
    "@higma-primitives/identifier": "workspace:*",
    "@higma-primitives/tree": "workspace:*"
  },
  "devDependencies": {
    "@higma-codecs/png": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "pixelmatch": "^7.2.0",
    "puppeteer": "^24.42.0"
  },
  "higma": {
    "boundary": {
      "layer": 7,
      "family": "tools",
      "product": "fig"
    }
  }
}
