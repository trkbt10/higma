{
  "name": "@higma-tools/fig-to-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "bin": {
    "fig-to-web": "./src/cli/bin.ts"
  },
  "scripts": {
    "lint": "cd ../../.. && eslint packages/@higma-tools/fig-to-web/src",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir ../../..",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-tools/fig-to-web/src'"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./fig-source": {
      "types": "./src/fig-source/index.ts",
      "default": "./src/fig-source/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./emit": {
      "types": "./src/emit/index.ts",
      "default": "./src/emit/index.ts"
    },
    "./cli": {
      "types": "./src/cli/index.ts",
      "default": "./src/cli/index.ts"
    }
  },
  "dependencies": {
    "@higma-document-io/fig": "workspace:*",
    "@higma-document-models/fig": "workspace:*",
    "@higma-document-renderers/fig": "workspace:*",
    "@higma-primitives/tree": "workspace:*"
  },
  "higma": {
    "boundary": {
      "layer": 7,
      "family": "tools",
      "product": "fig"
    }
  }
}
