    },
    "./tree": {
      "types": "./src/tree/index.ts",
      "default": "./src/tree/index.ts"
    },
    "./diagnostics": {
      "types": "./src/diagnostics/index.ts",
      "default": "./src/diagnostics/index.ts"
    },
    "./diagnostics/defensive": {
      "types": "./src/diagnostics/defensive.ts",
      "default": "./src/diagnostics/defensive.ts"
    }
  },
  "dependencies": {
    "@higma/kiwi": "workspace:*",
    "@higma/zip": "workspace:*",
    "fzstd": "^0.1.1",
    "pako": "^2.1.0",
    "zstd-codec": "^0.1.5"
  },
  "devDependencies": {
    "@types/pako": "^2.0.4"
  }
