{
  "name": "@higma/fig",
  "version": "0.12.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir ../../..",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma/fig/src'"
  },
  "exports": {
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "default": "./src/errors.ts"
    },
    "./parser": {
      "types": "./src/parser/index.ts",
      "default": "./src/parser/index.ts"
    },
    "./compression": {
      "types": "./src/compression/index.ts",
      "default": "./src/compression/index.ts"
    },
    "./validator": {
      "types": "./src/validator/index.ts",
      "default": "./src/validator/index.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./color": {
      "types": "./src/color.ts",
      "default": "./src/color.ts"
    },
    "./matrix": {
      "types": "./src/matrix.ts",
      "default": "./src/matrix.ts"
    },
    "./symbols": {
      "types": "./src/symbols/index.ts",
