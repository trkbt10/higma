{
  "name": "@higma-document-editors/site",
  "version": "0.12.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "lint": "cd ../../.. && eslint packages/@higma-document-editors/site/src packages/@higma-document-editors/site/dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-document-editors/site/src'",
    "e2e": "vitest --run --config ../../../vitest.config.ts --environment jsdom spec/e2e",
    "dev": "vite --config dev/vite.config.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@higma-document-models/fig": "workspace:*",
    "@higma-document-models/site": "workspace:*",
    "@higma-document-io/site": "workspace:*",
    "@higma-document-renderers/fig": "workspace:*",
    "@higma-document-renderers/site": "workspace:*",
    "@higma-editor-kernel/core": "workspace:*",
    "@higma-editor-kernel/ui": "workspace:*",
    "@higma-editor-surfaces/controls": "workspace:*",
    "@higma-editor-surfaces/sessions": "workspace:*",
    "@higma-figma-runtime/react-renderer": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "higma": {
    "boundary": {
      "layer": 7,
      "family": "document-editor",
      "product": "site"
    }
  }
}
