{
  "name": "@higma-document-editors/buzz",
  "version": "0.12.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "lint": "eslint src dev spec/e2e",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@higma-document-editors/buzz/src'",
    "e2e": "vitest --run --config ../../../vitest.config.ts --environment jsdom spec/e2e",
    "dev": "vite --config dev/vite.config.ts --open"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@higma-document-models/buzz": "workspace:*",
    "@higma-document-io/buzz": "workspace:*",
    "@higma-document-renderers/buzz": "workspace:*",
    "@higma-editor-surfaces/sessions": "workspace:*"
  },
  "higma": {
    "boundary": {
      "layer": 7,
      "family": "document-editor",
      "product": "buzz"
    }
  }
}
